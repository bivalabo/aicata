# Shopify App設定
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here
SCOPES=write_themes,read_themes,write_content,read_content,read_products,read_orders,read_analytics

# アプリURL（開発時はShopify CLIが自動設定）
SHOPIFY_APP_URL=https://your-app-url.trycloudflare.com

# データベース（PostgreSQL）
DATABASE_URL=postgresql://aicata:aicata_dev_password@localhost:5432/aicata_dev

# Redis
REDIS_URL=redis://localhost:6379

# Claude API（Anthropic）
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# AIモデル設定
CLAUDE_MODEL_DEFAULT=claude-sonnet-4-20250514
CLAUDE_MODEL_ADVANCED=claude-opus-4-20250514
CLAUDE_MAX_TOKENS=4096

# アプリ設定
APP_ENV=development
APP_LOCALE=ja
