# ===========================
# Aicata プロジェクト .gitignore
# ===========================

# -- 依存関係 --
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# -- ビルド成果物 --
/build/
dist/
.cache/
.next/
out/

# -- 環境変数・シークレット --
.env
.env.local
.env.*.local
web/.env.local
web/.env.*.local

# -- Shopify CLI --
.shopify/

# -- Prisma (DBファイルのみ除外。マイグレーションはコミットする) --
prisma/*.db
prisma/*.db-journal
prisma/data/
web/prisma/data/
web/prisma/*.db
web/prisma/*.db-journal

# -- OS・エディタ --
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace

# -- ログ・デバッグ --
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# -- テスト --
coverage/

# -- TypeScript --
*.tsbuildinfo
next-env.d.ts

# -- Vercel --
.vercel

# -- その他 --
*.pem
.sync-marker
.env*.local
